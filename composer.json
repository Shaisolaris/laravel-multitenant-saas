{
    "name": "solaris/laravel-multitenant-saas",
    "description": "Laravel 11 multi-tenant SaaS — tenant isolation, Cashier billing, RBAC, team management, API keys, usage tracking",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/cashier": "^15.0",
        "laravel/sanctum": "^4.0",
        "spatie/laravel-permission": "^6.0",
        "stancl/tenancy": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    }
}
